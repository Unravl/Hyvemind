# Sentry — crash reporting
# ---------------------------------------------------------------
# All Sentry env vars are optional. Hyvemind runs fine without any of them;
# Sentry simply stays disabled.

# Baked into the binary at build time (via option_env! in src-tauri).
# Set this only when producing a release that should report to your Sentry
# project. Users should NOT set this — leave the bake unset for personal
# builds.
#   SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
SENTRY_DSN=

# Sourcemap and debug-info upload at build time. Required only on the
# release machine / CI runner that runs `npm run tauri:build`.
#   SENTRY_ORG=hyvemind
#   SENTRY_PROJECT=desktop
#   SENTRY_AUTH_TOKEN=sntrys_xxx...
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Runtime kill switch. Overrides everything else (config toggle, baked DSN).
# Set to 1 to ensure Sentry stays off for this run.
#   SENTRY_DISABLED=1
SENTRY_DISABLED=
