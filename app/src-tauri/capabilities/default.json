{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "dialog:allow-message",
    "sentry:default",
    "core:webview:allow-set-webview-zoom",
    "core:window:allow-start-dragging"
  ]
}
