/target/

# Pi distribution build artifacts (built by scripts/build-pi.sh)
# Keep only the compiled pi-<target-triple> binary that ships with the app.
app/src-tauri/binaries/*
!app/src-tauri/binaries/pi-*-apple-darwin
!app/src-tauri/binaries/pi-*-linux-*
!app/src-tauri/binaries/pi-*-windows-*
